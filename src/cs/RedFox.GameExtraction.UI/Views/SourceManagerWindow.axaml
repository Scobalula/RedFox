<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RedFox.GameExtraction.UI.Views.SourceManagerWindow"
        Title="Manage Sources"
        Width="600" Height="400"
        MinWidth="400" MinHeight="250"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="16">
        <Panel>
            <!-- Shadow layer � renders freely outside bounds -->
            <Border CornerRadius="12"
                    BoxShadow="0 3 12 0 #40000000"
                    Background="#1C1C1F"
                    IsHitTestVisible="False"/>
            <!-- Content layer � clips scrollbar at rounded corners -->
            <Border Classes="sidebar" Padding="0" ClipToBounds="True">
                <DockPanel>
                <!-- Header inside the pane -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#2A2A2E"
                        BorderThickness="0,0,0,1"
                        Padding="16,14,16,12">
                    <TextBlock Text="Loaded Sources"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#E4E4EA"/>
                </Border>

                <!-- Source list -->
                <ListBox x:Name="SourceList"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.AllowAutoHide="False">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Margin" Value="2,1"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#2A2A30"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
                </DockPanel>
            </Border>
        </Panel>
    </DockPanel>
</Window>
