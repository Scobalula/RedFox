<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RedFox.GameExtraction.UI.ViewModels"
        x:Class="RedFox.GameExtraction.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Config.WindowTitle}"
        Width="1280" Height="780"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen">

    <Panel>
        <DockPanel IsEnabled="{Binding !IsLoading}">
            <Panel DockPanel.Dock="Bottom" Margin="8,6,8,8">
                <Border Classes="status-bar">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="status-text"
                                   Text="{Binding StatusText}"/>
                        <TextBlock Grid.Column="1"
                                   Classes="status-text"
                                   Text="{Binding AssetCountDisplay}"
                                   Margin="20,0,0,0"/>
                    </Grid>
                </Border>
            </Panel>

            <Panel DockPanel.Dock="Left" Margin="8,8,6,6" Width="274">
                <Border Classes="sidebar">
                    <Panel>
                        <Border IsHitTestVisible="False"
                                CornerRadius="12"
                                Background="{DynamicResource AccentRadialGlow}"/>

                        <Border Padding="16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Spacing="2" Margin="0,8,0,0">
                                    <Separator Classes="sidebar-sep"/>
                                    <Button Classes="sidebar-btn"
                                            Command="{Binding OpenSettingsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="sidebar-btn"
                                            Command="{Binding OpenAboutCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <PathIcon Data="{StaticResource IconInfo}" Width="16" Height="16"/>
                                            <TextBlock Text="About" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              AllowAutoHide="False">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,16">
                                            <Image Grid.Column="0" Grid.RowSpan="2"
                                                   Source="{Binding SidebarIcon}"
                                                   Stretch="Uniform"
                                                   Width="32" Height="32"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   IsVisible="{Binding HasSidebarIcon}"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Classes="sidebar-title"
                                                       Text="{Binding SidebarTitle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                       Classes="sidebar-desc"
                                                       Text="{Binding SidebarDescription}"
                                                       Margin="0"/>
                                        </Grid>

                                        <TextBlock Classes="sidebar-section" Text="Sources"/>
                                        <Button Classes="accent-btn"
                                                Command="{Binding BrowseProcessCommand}"
                                                IsVisible="{Binding CanLoadProcess}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconGamepad}" Width="16" Height="16"/>
                                                <TextBlock Text="Load Process" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="sidebar-btn"
                                                Command="{Binding LoadDirectoryCommand}"
                                                IsVisible="{Binding CanLoadDirectories}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconFolder}" Width="16" Height="16"/>
                                                <TextBlock Text="Load Folder" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="accent-btn"
                                                Command="{Binding LoadSourceCommand}"
                                                IsVisible="{Binding CanLoadFiles}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconFolder}" Width="16" Height="16"/>
                                                <TextBlock Text="Load Files" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="sidebar-btn"
                                                Command="{Binding ManageSourcesCommand}"
                                                IsVisible="{Binding CanLoadAnySource}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconList}" Width="16" Height="16"/>
                                                <TextBlock Text="{Binding SourceCountDisplay}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="sidebar-btn"
                                                Command="{Binding ClearAllCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconList}" Width="16" Height="16"/>
                                                <TextBlock Text="Clear All" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Separator Classes="sidebar-sep"/>

                                        <TextBlock Classes="sidebar-section" Text="Export"/>
                                        <Button Classes="sidebar-btn"
                                                Command="{Binding PreviewSelectedCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconInfo}" Width="16" Height="16"/>
                                                <TextBlock Text="Preview Selected" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="accent-btn"
                                                Command="{Binding ExportAllCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconExport}" Width="16" Height="16"/>
                                                <TextBlock Text="Export All" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="sidebar-btn"
                                                Command="{Binding ExportSelectedCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <PathIcon Data="{StaticResource IconExport}" Width="16" Height="16"/>
                                                <TextBlock Text="Export Selected" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Panel>
                </Border>
            </Panel>

            <DockPanel Margin="12,8,16,6">
                <Border DockPanel.Dock="Top"
                        Classes="search-container"
                        Margin="0,0,0,10">
                    <TextBox Classes="search-box"
                             Text="{Binding SearchText, Mode=TwoWay}"/>
                </Border>

                <Border DockPanel.Dock="Top"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Classes="status-text">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} of {1:N0} assets shown">
                                    <Binding Path="FilteredCount"/>
                                    <Binding Path="TotalCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Panel>
                    <Border CornerRadius="8"
                            BoxShadow="0 3 12 0 #40000000"
                            Background="#1F1F22"
                            IsHitTestVisible="False"/>
                    <Border Classes="card-subtle" Padding="0" ClipToBounds="True">
                        <DataGrid x:Name="AssetDataGrid"
                                  x:CompileBindings="False"
                                  ItemsSource="{Binding AssetsView}"
                                  SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  ScrollViewer.AllowAutoHide="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeight="32"
                                  SelectionChanged="OnAssetSelectionChanged"
                                  DoubleTapped="OnAssetDoubleTapped">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="140"/>
                                <DataGridTextColumn Header="Information" Binding="{Binding Information}" Width="3*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Panel>
            </DockPanel>
        </DockPanel>

        <Border Classes="progress-overlay"
                IsVisible="{Binding ShowProgressDialog}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Classes="progress-card"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    DataContext="{Binding ProgressDialog}">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding Title}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <ProgressBar Classes="themed"
                                 Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Maximum="100"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#909096"
                               FontSize="12"/>
                    <TextBlock Text="{Binding ProgressText}"
                               Foreground="#78787E"
                               FontSize="11"
                               HorizontalAlignment="Right"/>
                    <Button Classes="cancel-btn"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding !IsCancelling}"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</Window>
