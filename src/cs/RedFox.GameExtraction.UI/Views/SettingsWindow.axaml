<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RedFox.GameExtraction.UI.ViewModels"
        x:Class="RedFox.GameExtraction.UI.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings"
        Width="560" Height="520"
        MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="12">
        <Panel>
            <!-- Shadow layer — renders freely outside bounds -->
            <Border CornerRadius="12"
                    BoxShadow="0 3 12 0 #40000000"
                    Background="#1C1C1F"
                    IsHitTestVisible="False"/>
            <!-- Content layer — clips scrollbar at rounded corners -->
            <Border Classes="sidebar" ClipToBounds="True">
                <DockPanel>
                <!-- Action bar docked to bottom inside the pane -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#2A2A2E"
                        BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Classes="cancel-btn"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Width="90"/>
                        <Button Classes="accent-btn"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                Width="90"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable settings content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              AllowAutoHide="False">
                    <ItemsControl ItemsSource="{Binding Groups}"
                                  Margin="16,12,16,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <!-- Category header -->
                                    <TextBlock Classes="setting-category"
                                               Text="{Binding Category}"/>
                                    <Border Classes="card-subtle" Margin="0,4,0,8">
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SettingItem">
                                                    <StackPanel Margin="0,4">
                                                        <!-- Boolean: CheckBox -->
                                                        <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                                  Content="{Binding DisplayName}"
                                                                  IsVisible="{Binding IsBool}"
                                                                  Margin="0,2,0,2"
                                                                  Foreground="#E4E4EA"/>

                                                        <!-- Non-bool label -->
                                                        <TextBlock Classes="setting-label"
                                                                   Text="{Binding DisplayName}"
                                                                   IsVisible="{Binding !IsBool}"/>

                                                        <!-- Description (always shown if present) -->
                                                        <TextBlock Classes="setting-desc"
                                                                   Text="{Binding Description}"
                                                                   IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                        <!-- TextBox for text/numeric -->
                                                        <TextBox Text="{Binding TextValue, Mode=TwoWay}"
                                                                 IsVisible="{Binding IsText}"
                                                                 Margin="0,2,0,6"
                                                                 CornerRadius="6"
                                                                 Padding="8,6"/>

                                                        <!-- ComboBox for enums -->
                                                        <ComboBox ItemsSource="{Binding EnumValues}"
                                                                  SelectedItem="{Binding EnumSelectedValue, Mode=TwoWay}"
                                                                  IsVisible="{Binding IsEnum}"
                                                                  Margin="0,2,0,6"
                                                                  CornerRadius="6"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </DockPanel>
            </Border>
        </Panel>
    </DockPanel>
</Window>
