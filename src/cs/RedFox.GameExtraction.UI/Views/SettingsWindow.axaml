<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:RedFox.GameExtraction.UI.ViewModels"
		x:Class="RedFox.GameExtraction.UI.Views.SettingsWindow"
		x:DataType="vm:SettingsWindowViewModel"
		Title="Settings"
		Width="560" Height="360"
		MinWidth="480" MinHeight="320"
		WindowStartupLocation="CenterOwner"
		CanResize="True">

	<DockPanel Margin="12">
		<Border DockPanel.Dock="Bottom"
				Classes="settings-action-bar"
				Margin="0,10,0,0">
				<Grid>
					<Button Classes="cancel-btn"
						Content="Open Log Folder"
						Command="{Binding OpenLogCommand}"/>
					<StackPanel Orientation="Horizontal"
						HorizontalAlignment="Right"
						Spacing="8">
					<Button Classes="cancel-btn"
						Content="Cancel"
						Command="{Binding CancelCommand}"
						Width="90"/>
					<Button Classes="accent-btn"
						Content="Save"
						Command="{Binding SaveCommand}"
						Width="90"/>
					</StackPanel>
				</Grid>
			</Border>

			<Border Classes="sidebar" Padding="0" ClipToBounds="True">
				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
				<ItemsControl ItemsSource="{Binding Groups}" Margin="15,15,15,5">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:SettingGroupViewModel">
							<StackPanel Spacing="10" Margin="0,0,0,0">
								<TextBlock Classes="setting-category" Text="{Binding Name}" Margin="0,0,0,2"/>
								<ItemsControl ItemsSource="{Binding Settings}">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:GameExtractionSettingViewModel">
											<StackPanel Spacing="6" Margin="0,0,0,8">
												<TextBlock Classes="setting-label"
														   Text="{Binding Label}"
														   IsVisible="{Binding ShowLabel}"/>
												<TextBox Text="{Binding TextValue, Mode=TwoWay}"
														 CornerRadius="6"
														 Padding="8,6"
														 IsVisible="{Binding IsTextBox}"/>
												<Grid ColumnDefinitions="*,Auto"
													  ColumnSpacing="8"
													  IsVisible="{Binding IsPathSetting}">
													<TextBox Grid.Column="0"
															 Text="{Binding TextValue, Mode=TwoWay}"
															 CornerRadius="6"
															 Padding="8,6"/>
													<Button Grid.Column="1"
															Classes="sidebar-btn"
															Content="Browse"
															Command="{Binding BrowseCommand}"
															Width="96"/>
												</Grid>
												<ComboBox ItemsSource="{Binding Options}"
														  SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
														  IsVisible="{Binding IsComboBox}"/>
												<CheckBox IsChecked="{Binding BooleanValue, Mode=TwoWay}"
														  Content="{Binding Label}"
														  Foreground="#E4E4EA"
														  IsVisible="{Binding IsCheckBox}"/>
												<TextBlock Classes="setting-desc"
														   Text="{Binding Description}"
														   IsVisible="{Binding HasDescription}"/>
											</StackPanel>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				</ScrollViewer>
			</Border>
	</DockPanel>
</Window>
