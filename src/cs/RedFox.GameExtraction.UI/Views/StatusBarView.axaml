<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedFox.GameExtraction.UI.ViewModels"
             x:Class="RedFox.GameExtraction.UI.Views.StatusBarView"
             x:DataType="vm:StatusBarViewModel">

    <!-- Margin gives the BoxShadow internal space to render within this UC's bounds -->
    <Panel Margin="8,6,8,8">
        <Border Classes="status-bar">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status-text"
                           Text="{Binding StatusText}"/>
                <TextBlock Grid.Column="1"
                           Classes="status-text"
                           Text="{Binding AssetCountDisplay}"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>
    </Panel>
</UserControl>
