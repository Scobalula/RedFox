<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedFox.GameExtraction.UI.ViewModels"
             x:Class="RedFox.GameExtraction.UI.Views.AssetListView"
             x:DataType="vm:AssetListViewModel">

    <DockPanel Margin="12,8,16,6">
        <!-- Search Bar -->
        <Border DockPanel.Dock="Top"
                Classes="search-container"
                Margin="0,0,0,10">
            <TextBox Classes="search-box"
                     Text="{Binding SearchText, Mode=TwoWay}"/>
        </Border>

        <!-- Asset Count Info -->
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Classes="status-text">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:N0} of {1:N0} assets shown">
                            <Binding Path="FilteredCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Asset List -->
        <Panel>
            <!-- Shadow layer -->
            <Border CornerRadius="10"
                    BoxShadow="0 3 12 0 #40000000"
                    Background="#1F1F22"
                    IsHitTestVisible="False"/>
            <!-- Content layer — clips scrollbar at rounded corners -->
            <Border Classes="card-subtle" Padding="0" ClipToBounds="True">
                <ListBox x:Name="AssetListBox"
                     ItemsSource="{Binding Assets}"
                     SelectionMode="Multiple"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.AllowAutoHide="False"
                     SelectionChanged="OnSelectionChanged"
                     DoubleTapped="OnAssetDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,140,120" Margin="8,6">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#E4E4EA"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Information}"
                                           Foreground="#68686E"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Type}"
                                       Foreground="#909096"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="16,0"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Information}"
                                       Foreground="#78787E"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       TextAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0,2"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Margin" Value="1,1"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#303036"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#2A2A30"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
            </Border>
        </Panel>
    </DockPanel>
</UserControl>
