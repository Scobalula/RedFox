<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:RedFox.GameExtraction.UI"
        x:Class="RedFox.GameExtraction.UI.Views.AboutWindow"
        Title="About"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Panel>
        <!-- Accent glow overlay (same as sidebar) -->
        <Border IsHitTestVisible="False"
                Background="{DynamicResource AccentRadialGlow}"/>

        <!-- Content -->
        <StackPanel Margin="28,24" Spacing="0">
            <!-- Icon + Title + Version -->
            <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,12">
                <Image x:Name="AppIcon"
                       Width="48" Height="48"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
                <TextBlock x:Name="AppTitle"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="AppVersion"
                           FontSize="13"
                           Foreground="#78787E"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Description -->
            <TextBlock x:Name="AppDescription"
                       FontSize="13"
                       Foreground="#A0A0A6"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       MaxWidth="340"
                       Margin="0,0,0,16"/>

            <!-- Links section (separator + buttons) -->
            <StackPanel x:Name="LinksSection" Margin="0,0,0,12">
                <Separator Background="#2A2A2E" Margin="0,0,0,8"/>
                <ItemsControl x:Name="LinksPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:AboutLink">
                            <Button Classes="sidebar-btn" Click="OnLinkClick" Tag="{Binding Url}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconExternalLink}" Width="14" Height="14"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator Background="#2A2A2E" Margin="0,4"/>

            <!-- Footer -->
            <StackPanel Spacing="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="Built with RedFox.GameExtraction.UI"
                           FontSize="11"
                           Foreground="#58585E"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Powered by Avalonia UI"
                           FontSize="11"
                           Foreground="#58585E"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Button Classes="cancel-btn"
                    Content="Close"
                    HorizontalAlignment="Center"
                    Click="OnCloseClick"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    Margin="0,12,0,0"/>
        </StackPanel>
    </Panel>
</Window>
