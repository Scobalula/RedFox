<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="#161618" />
    <Setter Property="Foreground" Value="#A4A4AA" />
    <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Mono, Consolas, monospace" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Border">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="PopupRoot Border">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Border.sample-toolbar">
    <Setter Property="Background" Value="#1E1E21" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.sidebar-host">
    <Setter Property="Background" Value="#1E1E21" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Border.viewport-host">
    <Setter Property="Background" Value="#161618" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Border.timeline-bar">
    <Setter Property="Background" Value="#171719" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style Selector="Border.status-bar">
    <Setter Property="Background" Value="#171719" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style Selector="TextBlock.status-text">
    <Setter Property="Foreground" Value="#78787E" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.section-header">
    <Setter Property="Foreground" Value="#0B7D92" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="#333338" />
    <Setter Property="Background" Value="#2A2A2E" />
    <Setter Property="Foreground" Value="#C4C4CA" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button /template/ ContentPresenter">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#343437" />
    <Setter Property="BorderBrush" Value="#404044" />
    <Setter Property="Foreground" Value="#E4E4EA" />
  </Style>

  <Style Selector="Button:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#3C3C40" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#0B7D92" />
    <Setter Property="BorderBrush" Value="#0B7D92" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1093AA" />
    <Setter Property="BorderBrush" Value="#1093AA" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#07677A" />
    <Setter Property="BorderBrush" Value="#07677A" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.toolbar-btn">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#A0A0A6" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2A2D30" />
    <Setter Property="Foreground" Value="#E4E4EA" />
  </Style>

  <Style Selector="Button.toolbar-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#333338" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="#1E1E22" />
    <Setter Property="BorderBrush" Value="#333338" />
    <Setter Property="Foreground" Value="#E0E0E6" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="ComboBox /template/ Border">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#E0E0E6" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#2A2A2E" />
  </Style>

  <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="#0F2F36" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="#E0E0E6" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="#1E1E21" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#E4E4EA" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem /template/ ContentPresenter">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#242428" />
  </Style>

  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="#0F2F36" />
  </Style>

  <Style Selector="TreeView">
    <Setter Property="Background" Value="#1E1E21" />
    <Setter Property="BorderBrush" Value="#2A2A2E" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#E4E4EA" />
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="GridSplitter">
    <Setter Property="Background" Value="#2A2A2E" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Height" Value="24" />
    <Setter Property="Foreground" Value="#0B7D92" />
    <Setter Property="Background" Value="#2A2A2E" />
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="AllowAutoHide" Value="False" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="#3A3A3E" />
  </Style>

</Styles>